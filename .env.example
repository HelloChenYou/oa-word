APP_ENV=dev
APP_PORT=8080
ADMIN_API_TOKEN=
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=postgresql+psycopg://proofread:proofread@postgres:5432/proofread
REDIS_URL=redis://redis:6379/0

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_MODEL=qwen2.5-7b-instruct-1m
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

DEFAULT_TIMEOUT_SEC=600
RQ_RESULT_TTL_SEC=86400
MAX_TASK_TEXT_CHARS=20000
MAX_TEMPLATE_FILE_BYTES=2097152
MAX_TEMPLATE_TEXT_CHARS=50000
MAX_ISSUES_PER_TASK=200
MAX_ACTIVE_TASKS=20
SUBMIT_RATE_LIMIT_WINDOW_SEC=60
SUBMIT_RATE_LIMIT_MAX_REQUESTS=10
MAX_ERROR_MSG_CHARS=2000
TASK_MAX_RETRIES=1
RETRYABLE_TASK_ERROR_TYPES=timeout,llm_http_error,unknown_error
